<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.Bar.Mar.GUI.SanctuaryGUIController">
   <children>
      <StackPane>
         <children>
            <VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="300.0" prefWidth="400.0" style="-fx-background-color: #161616;">
               <children>
                  <HBox VBox.vgrow="NEVER">
                     <children>
                        <Label text="SANCTUARY Status:" textFill="#c6c6c6">
                           <font>
                              <Font size="18.0" />
                           </font>
                        </Label>
                        <Label fx:id="statusLabel" alignment="CENTER" text="Synced" textAlignment="CENTER" textFill="#52e100" HBox.hgrow="ALWAYS">
                           <padding>
                              <Insets left="12.0" top="6.0" />
                           </padding>
                        </Label>
                     </children>
                     <padding>
                        <Insets left="8.0" top="8.0" />
                     </padding>
                     <VBox.margin>
                        <Insets bottom="4.0" />
                     </VBox.margin>
                  </HBox>
                  <ScrollPane style="-fx-background-color: black; -fx-text-fill: orange;">
                     <content>
                        <VBox>
                           <children>
                              <HBox VBox.vgrow="ALWAYS">
                                 <children>
                                    <ListView fx:id="watchServiceList" editable="true" style="-fx-background-color: blue;" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>
                  <HBox alignment="CENTER">
                     <children>
                        <Button fx:id="commitButton" mnemonicParsing="false" onAction="#handleCommitAndPush" text="Commit &amp; Push" />
                     </children>
                     <VBox.margin>
                        <Insets top="6.0" />
                     </VBox.margin>
                  </HBox>
                  <HBox alignment="CENTER">
                     <children>
                        <Button mnemonicParsing="false" onAction="#handleCreateMasterList" text="Create Master List" />
                     </children>
                  </HBox>
                  <Button mnemonicParsing="false" onAction="#doTestAction" text="Test" />
                  <HBox>
                     <children>
                        <Label text="CPU: 10%" textFill="#5367ff" />
                        <Separator orientation="VERTICAL">
                           <HBox.margin>
                              <Insets left="6.0" right="6.0" />
                           </HBox.margin>
                        </Separator>
                        <Label text="Mem: 15%" textFill="#fc689b" />
                     </children>
                  </HBox>
                  <HBox spacing="16.0">
                     <children>
                        <RadioButton fx:id="cloudRadio" mnemonicParsing="false" selected="true" text="Cloud" textFill="WHITE">
                           <toggleGroup>
                              <ToggleGroup fx:id="Model" />
                           </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="localRadio" mnemonicParsing="false" text="Local" textFill="WHITE" toggleGroup="$Model" />
                     </children>
                     <VBox.margin>
                        <Insets top="8.0" />
                     </VBox.margin>
                  </HBox>
               </children>
            </VBox>
            <VBox disable="true" style="-fx-background-color: #2dceff70;">
               <cursor>
                  <Cursor fx:constant="DEFAULT" />
               </cursor>
            </VBox>
         </children>
      </StackPane>
   </children>
</VBox>
